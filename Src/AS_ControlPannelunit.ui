  <property name="styleSheet">
   <string notr="true">/* Main Background */
QMainWindow {
    background-color: #0b1220;
}

QWidget {
    background-color: #0b1220;
    color: #d1d5db;
    font-family: Segoe UI;
    font-size: 14px;
}

/* Title */
QLabel#titleLabel {
    font-size: 22px;
    font-weight: bold;
    color: #22d3ee;   /* soft cyan */
    padding: 8px;
}

/* Section Labels */
QLabel#sectionLabel {
    font-size: 15px;
    font-weight: bold;
    color: #60a5fa;   /* light blue */
}

/* Group Box */
QGroupBox {
    border: 1.5px solid #334155;
    border-radius: 10px;
    margin-top: 10px;
    background-color: #020617;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #38bdf8;
}

/* Buttons */
QPushButton {
    background-color: #1f2937;
    border: 1.5px solid #475569;
    border-radius: 10px;
    padding: 8px;
    color: #e5e7eb;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #334155;
    border: 1.5px solid #38bdf8;
}

QPushButton:pressed {
    background-color: #1d4ed8;
}

/* ACTIVE BUTTON (antenna selected) */
QPushButton:checked {
    background-color: #2563eb;   /* blue */
    color: white;
    border: 2px solid #60a5fa;
}

/* ComboBox */
QComboBox {
    background-color: #020617;
    border: 1.5px solid #475569;
    border-radius: 8px;
    padding: 5px;
    color: #e5e7eb;
}

QComboBox:hover {
    border: 1.5px solid #38bdf8;
}

QComboBox:focus {
    border: 1.5px solid #2563eb;
}

/* Dropdown */
QComboBox QAbstractItemView {
    background-color: #020617;
    border: 1px solid #475569;
    selection-background-color: #2563eb;
    selection-color: white;
}

/* Line Edit */
QLineEdit {
    background-color: #020617;
    border: 1.5px solid #475569;
    border-radius: 8px;
    padding: 5px;
    color: #e5e7eb;
}

QLineEdit:focus {
    border: 1.5px solid #2563eb;
}

/* General Labels */
QLabel {
    color: #d1d5db;
font:18px;
}</string>
